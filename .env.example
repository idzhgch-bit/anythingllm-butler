# AnythingLLM Butler - Environment Variables Template
# Copy this file to .env and fill in your values
# ⚠️ IMPORTANT: Replace the placeholder below with YOUR actual API Key!

ANYSHEM_LLAMA_API_KEY=[YOUR_API_KEY_HERE]
ANYSHEM_HOST=192.168.1.16
ANYSHEM_PORT=3001

