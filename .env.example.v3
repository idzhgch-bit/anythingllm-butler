# 🔐 AnythingLLM Butler - V3.0 Hot-Pluggable Configuration Template
# 
# 📝 说明:
# 1. 复制此文件为 .env (不要提交到 Git)
# 2. 填入您的真实 API Key 和工作区 ID
# 3. 支持动态添加/删除工作区，无需修改代码!
#
# ⚠️ 安全警告:
# - NEVER commit your real .env file to Git!
# - Use placeholders for public repositories
# - Rotate API Keys quarterly

# 🔑 AnythingLLM API Key (获取方式：Settings → API Keys)
ANYSHEM_LLAMA_API_KEY=your-real-api-key-here

# 🌐 Server Configuration
ANYSHEM_HOST=192.168.1.16
ANYSHEM_PORT=3001

# 🗂️ Workspace IDs (热插拔配置 - 修改此文件即可动态管理工作区)
# 
# 格式：WORKSPACES_<NAME>_ID=<UUID>
# 支持添加任意数量的工作区，只需添加新行!
#
# 🔍 如何获取 UUID:
# 1. 登录 AnythingLLM 管理后台
# 2. 进入对应工作区设置
# 3. 复制 URL 中的 UUID (格式：xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)

# 🏛️ Party 工作区 (党建/政务相关)
WORKSPACES_PARTY_ID=7ec9cd49-afa3-4594-b370-d7f168c60bf0

# 💼 Work 工作区 (生产/技术相关)
WORKSPACES_WORK_ID=9bf38924-c218-4e84-ba05-5e9ba1de49e9

# 🏠 Life 工作区 (个人/生活记录)
WORKSPACES_LIFE_ID=5bcfe47e-8e0e-4fb2-9828-02a016eebcb4

# ✨ 可选：添加自定义工作区 (示例)
# WORKSPACES_PROJECT_X_ID=abc-def-ghi-jkl-mno-pqr

# 📝 关键词映射规则:
# - party: "party", "党建", "共建", "政务", "方案"
# - work: "work", "工作", "技术", "通报", "生产", "维护"
# - life: "life", "生活", "个人", "记录", "日记"
